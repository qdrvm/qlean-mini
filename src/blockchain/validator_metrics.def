/// Validator metrics definitions

// Validators count
// On scrape
METRIC_GAUGE(val_validators_count,
             "lean_validators_count",
             "Number of validators managed by a node")

METRIC_GAUGE(lean_is_aggregator,
             "lean_is_aggregator",
             "Validator's `is_aggregator` status. True=1, False=0")

METRIC_HISTOGRAM(lean_attestations_production_time_seconds,
                 "lean_attestations_production_time_seconds",
                 "Time taken to produce attestation",
                 (0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 0.75, 1))
